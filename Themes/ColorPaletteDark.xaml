<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:sys="clr-namespace:System;assembly=mscorlib">
  <!-- Dark Theme (Gruvbox / Kanagawa inspired) -->

  <!-- Font Sizes (base values, can be scaled by ThemeService) -->
  <sys:Double x:Key="FontSize.Small">10</sys:Double>
  <sys:Double x:Key="FontSize.Base">13</sys:Double>
  <sys:Double x:Key="FontSize.Medium">14</sys:Double>
  <sys:Double x:Key="FontSize.Large">16</sys:Double>
  <sys:Double x:Key="FontSize.Heading">18</sys:Double>
  <sys:Double x:Key="FontSize.StatCaption">12</sys:Double>
  <sys:Double x:Key="FontSize.Display">44</sys:Double>
  <!-- Hierarchy: PrimaryBackground (deepest) < PanelBackground < CardBackground (brightest) -->

  <!-- Colors -->
  <Color x:Key="Color.PrimaryBackground">#FF121214</Color>
  <Color x:Key="Color.PanelBackground">#FF1A1B1F</Color>
  <Color x:Key="Color.CardBackground">#FF282A32</Color>
  <Color x:Key="Color.Border">#FF3A3D48</Color>
  <Color x:Key="Color.Accent">#FF4D7A6D</Color>
  <Color x:Key="Color.AccentMuted">#FF3A5F54</Color>
  <Color x:Key="Color.Warning">#FFE67E80</Color>
  <Color x:Key="Color.TextPrimary">#FFECE0C8</Color>
  <Color x:Key="Color.TextSecondary">#FFB8B2A7</Color>
  <Color x:Key="Color.TextDisabled">#FF6E6A62</Color>

  <!-- Brushes (static, no DynamicResource chain) -->
  <SolidColorBrush x:Key="Brush.PrimaryBackground" Color="#FF121214" />
  <SolidColorBrush x:Key="Brush.PanelBackground" Color="#FF1A1B1F" />
  <SolidColorBrush x:Key="Brush.CardBackground" Color="#FF282A32" />
  <SolidColorBrush x:Key="Brush.Border" Color="#FF3A3D48" />
  <SolidColorBrush x:Key="Brush.Accent" Color="#FF4D7A6D" />
  <SolidColorBrush x:Key="Brush.AccentMuted" Color="#FF3A5F54" />
  <SolidColorBrush x:Key="Brush.Warning" Color="#FFE67E80" />
  <SolidColorBrush x:Key="Brush.TextPrimary" Color="#FFECE0C8" />
  <SolidColorBrush x:Key="Brush.TextSecondary" Color="#FFB8B2A7" />
  <SolidColorBrush x:Key="Brush.TextDisabled" Color="#FF6E6A62" />

  <!-- Opacity variants -->
  <SolidColorBrush x:Key="Brush.BorderLight" Color="#FF3A3D48" Opacity="0.5" />
  <SolidColorBrush x:Key="Brush.HighlightOverlay" Color="#FF4D7A6D" Opacity="0.12" />

  <!-- Semantic colors (Info = blue, Conflict = amber, Success = accent green) -->
  <!-- Brush.Warning (red) is reserved for errors / destructive actions only. -->
  <Color x:Key="Color.Info">#FF5B8AA6</Color>
  <Color x:Key="Color.Conflict">#FFC8943B</Color>
  <Color x:Key="Color.Success">#FF4D7A6D</Color>

  <SolidColorBrush x:Key="Brush.Info" Color="#FF5B8AA6" />
  <SolidColorBrush x:Key="Brush.Conflict" Color="#FFC8943B" />
  <SolidColorBrush x:Key="Brush.Success" Color="#FF4D7A6D" />

  <!-- Semantic surface fills (low-opacity backgrounds for notice panels) -->
  <SolidColorBrush x:Key="Brush.Info.Surface" Color="#FF5B8AA6" Opacity="0.12" />
  <SolidColorBrush x:Key="Brush.Conflict.Surface" Color="#FFC8943B" Opacity="0.15" />
  <SolidColorBrush x:Key="Brush.Success.Surface" Color="#FF4D7A6D" Opacity="0.12" />

  <!-- Distribution type badge colors (solid, white text) -->
  <SolidColorBrush x:Key="Brush.Type.Outfit" Color="#FF4D7A6D" />
  <SolidColorBrush x:Key="Brush.Type.Keyword" Color="#FF4A8BAF" />
  <SolidColorBrush x:Key="Brush.Type.ExclusiveGroup" Color="#FFB8860B" />

  <!-- Tutorial/GuideLine colors -->
  <SolidColorBrush x:Key="Brush.Tutorial.Overlay" Color="#FF000000" Opacity="0.75" />
  <SolidColorBrush x:Key="Brush.Tutorial.DialogBackground" Color="#FF1A1B1F" />
  <SolidColorBrush x:Key="Brush.Tutorial.DialogBorder" Color="#FF4D7A6D" />
  <SolidColorBrush x:Key="Brush.Tutorial.DialogForeground" Color="#FFECE0C8" />
  <SolidColorBrush x:Key="Brush.Tutorial.ButtonBackground" Color="#FF4D7A6D" />
  <SolidColorBrush x:Key="Brush.Tutorial.ButtonForeground" Color="#FF121214" />

  <!-- Parse Error colors -->
  <SolidColorBrush x:Key="Brush.Error.Background" Color="#FF3C2A2A" />
  <SolidColorBrush x:Key="Brush.Error.Border" Color="#FF8B4513" />
  <SolidColorBrush x:Key="Brush.Error.Title" Color="#FFFFB347" />
  <SolidColorBrush x:Key="Brush.Error.Text" Color="#FF999999" />
</ResourceDictionary>
